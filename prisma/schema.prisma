generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
}

enum TransactionStatus {
  CREATED
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

model Merchant {
  id            String   @id @default(cuid())
  name          String
  webhookUrl    String?
  webhookSecret String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  apiKeys       ApiKey[]
  customers     Customer[]
  txns          Transaction[]
}

model ApiKey {
  id         String       @id @default(cuid())
  merchantId String
  name       String
  keyHash    String
  prefix     String
  last4      String
  status     ApiKeyStatus @default(ACTIVE)
  version    Int          @default(1)
  createdAt  DateTime     @default(now())
  revokedAt  DateTime?
  merchant   Merchant     @relation(fields: [merchantId], references: [id])

  @@index([merchantId, status])
}

model Customer {
  id         String   @id @default(cuid())
  merchantId String
  externalId String?
  email      String?
  name       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  txns       Transaction[]

  @@unique([merchantId, externalId])
  @@unique([merchantId, email])
  @@index([merchantId, name])
}

model Transaction {
  id                String            @id @default(cuid())
  merchantId        String
  customerId        String?
  type              TransactionType
  status            TransactionStatus @default(CREATED)
  amount            Decimal
  currency          String
  reference         String            @unique
  externalRef       String?
  providerName      String?
  failureReason     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  merchant          Merchant          @relation(fields: [merchantId], references: [id])
  customer          Customer?         @relation(fields: [customerId], references: [id])
  audits            TransactionAudit[]
  callbackEvents    CallbackEvent[]
  webhookDeliveries WebhookDelivery[]

  @@index([merchantId, status])
  @@index([customerId, createdAt])
}

model TransactionAudit {
  id            String            @id @default(cuid())
  transactionId String
  fromStatus    TransactionStatus?
  toStatus      TransactionStatus
  note          String
  actor         String
  createdAt     DateTime          @default(now())
  transaction   Transaction        @relation(fields: [transactionId], references: [id])
}

model CallbackEvent {
  id            String      @id @default(cuid())
  transactionId String
  providerName  String
  eventId       String
  status        String
  payload       String
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@unique([providerName, eventId])
}

model WebhookDelivery {
  id            String                @id @default(cuid())
  transactionId String
  eventType     String
  payload       String
  signature     String
  status        WebhookDeliveryStatus @default(PENDING)
  attemptCount  Int                   @default(0)
  maxAttempts   Int                   @default(5)
  nextRetryAt   DateTime?
  lastError     String?
  deliveredAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  transaction   Transaction           @relation(fields: [transactionId], references: [id])

  @@index([status, nextRetryAt])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  scope        String
  key          String
  responseBody String
  createdAt    DateTime @default(now())

  @@unique([scope, key])
}

model AuditLog {
  id         String   @id @default(cuid())
  eventType  String
  actor      String
  entityType String
  entityId   String
  metadata   String
  createdAt  DateTime @default(now())
}
