{
  "name": "payment-gateway",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build:all": "npm run build && npm run frontend:build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "frontend:install": "npm --prefix frontend install",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend run preview",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts",
    "adjudication:replay:verify": "ts-node prisma/run-adjudication-replay-verifier.ts",
    "adjudication:payload:diff": "ts-node prisma/run-adjudication-payload-diff.ts",
    "settlements:fixtures:seed": "ts-node prisma/seed-settlement-exception-fixtures.ts",
    "settlements:fixtures:replay": "ts-node prisma/replay-settlement-exception-fixtures.ts",
    "payments:timeline:fixtures:seed": "ts-node prisma/seed-payment-attempt-timeline-fixtures.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
